           </property>
           <property name="sizeHint" stdset="0">
            <size>
             <width>40</width>
             <height>20</height>
            </size>
           </property>
          </spacer>
         </item>
         <item>
          <widget class="QPushButton" name="btnGetKarabinerDriver">
           <property name="toolTip">
            <string>Opens the Karabiner DriverKit VirtualHIDDevice releases page. Install the package and approve the system extension, then re-open this dialog.</string>
           </property>
           <property name="text">
            <string>Get Karabiner Driver...</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <spacer name="verticalSpacerLoginBridge">
         <property name="orientation">
          <enum>Qt::Orientation::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
