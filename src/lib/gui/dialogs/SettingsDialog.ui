          <enum>Qt::Orientation::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>0</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
     <widget class="QWidget" name="tabSharing">
      <attribute name="title">
       <string>S&amp;haring</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayoutSharing">
       <item>
        <widget class="QGroupBox" name="groupHidPassthrough">
         <property name="title">
          <string>Share Logitech controls (HID passthrough)</string>
         </property>
         <property name="checkable">
          <bool>true</bool>
         </property>
         <property name="checked">
          <bool>false</bool>
         </property>
         <layout class="QVBoxLayout" name="verticalLayoutHidPassthrough">
          <item>
           <widget class="QLabel" name="lblHidPassthroughHelp">
            <property name="text">
             <string>When the cursor is on another screen, takes the Logitech vendor interface away from Logitech Options+ on this computer and forwards raw HID++ reports to the focused computer. Requires the Mouser app on each computer.</string>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutHidDevices">
            <item>
             <widget class="QLabel" name="lblHidPassthroughDevices">
              <property name="text">
               <string>Devices</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QLineEdit" name="lineHidPassthroughDevices">
              <property name="toolTip">
               <string>&lt;html&gt;Vendor:product selectors for the mice to pass through, comma-separated.&lt;br&gt;&lt;b&gt;046D:*&lt;/b&gt; matches all Logitech devices; &lt;b&gt;046D:B042&lt;/b&gt; pins one model.&lt;/html&gt;</string>
              </property>
              <property name="placeholderText">
               <string>046D:*</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <widget class="QGroupBox" name="groupGestureSharing">
         <property name="title">
          <string>Share device controls (legacy Mouser bridge)</string>
         </property>
         <property name="checkable">
          <bool>true</bool>
         </property>
         <property name="checked">
          <bool>false</bool>
         </property>
         <layout class="QVBoxLayout" name="verticalLayoutGesture">
          <item>
           <widget class="QLabel" name="lblGestureHelp">
            <property name="text">
             <string>Alternative: Mouser on this computer reads gestures locally and relays them through Deskflow. Do not enable both sharing modes at once.</string>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="horizontalLayoutSecret">
         <item>
          <widget class="QLabel" name="lblGestureSecret">
           <property name="text">
            <string>Shared secret</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QLineEdit" name="lineGestureSecret">
           <property name="toolTip">
            <string>&lt;html&gt;A password shared between Deskflow and the Mouser app on this computer. Use the &lt;b&gt;same&lt;/b&gt; value on every computer and in each machine's Mouser settings.&lt;/html&gt;</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <spacer name="verticalSpacerSharing">
         <property name="orientation">
          <enum>Qt::Orientation::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
     <widget class="QWidget" name="tabLoginBridge">
      <attribute name="title">
       <string>Login &amp;Window</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayoutLoginBridge">
       <item>
        <widget class="QGroupBox" name="groupLoginBridge">
         <property name="title">
          <string>Control this computer at the login window</string>
         </property>
         <property name="checkable">
          <bool>true</bool>
         </property>
         <property name="checked">
          <bool>false</bool>
         </property>
         <layout class="QVBoxLayout" name="verticalLayoutLoginBridgeGroup">
          <item>
           <widget class="QLabel" name="lblLoginBridgeHelp">
            <property name="text">
             <string>macOS blocks normal input injection at the login window. The bundled bridge replays the controlling computer's input through the Karabiner virtual HID driver, so you can unlock this Mac from another machine. Runs only while the login window is showing; takes effect after the next logout or restart.</string>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutBridgeScale">
            <item>
             <widget class="QLabel" name="lblBridgeScale">
              <property name="text">
               <string>Pointer sensitivity</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QDoubleSpinBox" name="sbBridgeScale">
              <property name="toolTip">
               <string>Counts-per-point multiplier for relayed motion. 4.0 reaches the whole screen 1:1 on a 2x Retina display; lower is gentler but reaches less.</string>
              </property>
              <property name="minimum">
               <double>0.500000000000000</double>
              </property>
              <property name="maximum">
               <double>16.000000000000000</double>
              </property>
              <property name="singleStep">
               <double>0.500000000000000</double>
              </property>
              <property name="value">
               <double>4.000000000000000</double>
              </property>
             </widget>
            </item>
            <item>
             <spacer name="horizontalSpacerBridgeScale">
              <property name="orientation">
               <enum>Qt::Orientation::Horizontal</enum>
              </property>
              <property name="sizeHint" stdset="0">
               <size>
                <width>40</width>
                <height>20</height>
               </size>
              </property>
             </spacer>
            </item>
           </layout>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="horizontalLayoutBridgeStatus">
         <item>
          <widget class="QLabel" name="lblBridgeStatusCaption">
           <property name="text">
            <string>Driver status:</string>
           </property>
          </widget>
