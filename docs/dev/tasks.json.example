{
  // Build and install Deskflow on macOS or Windows.
  // Run in VS Code / Cursor: Terminal → Run Task… or the default build shortcut.
  //
  // macOS: DESKFLOW_CODESIGN_ID in .env or ~/.zshenv (Apple Development cert SHA-1).
  // Signing in a GUI/login-keychain context is required; signing over SSH fails.
  // SKIP_BUILD_TESTS=ON avoids OSXKeyStateTests build-time window-server requirement.
  //
  // Reinstall (Deskflow: Install locally / default build task step 3):
  //   macOS — scripts/install-macos.sh quits all processes, deploys to
  //           /Applications, relaunches with --show (menu bar + main window).
  //   Windows — scripts/install-windows.ps1 stops service/processes, deploys to
  //             Program Files, updates the service, launches deskflow.exe --show.
  //
  // Windows build: auto-detects Qt under C:\Qt. Optional Authenticode signing uses
  // DESKFLOW_SIGN_THUMBPRINT. Requires VS Build Tools + CMake 3.24+. See .env.example.
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}",
    "envFile": "${workspaceFolder}/.env"
  },
  "tasks": [
    {
      "label": "Deskflow: Configure (signed)",
      "type": "shell",
      "command": "set -a; [ -f .env ] && . ./.env; set +a; cmake -S . -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_PREFIX_PATH=\"$(brew --prefix qt);$(brew --prefix openssl@3)\" -DAPPLE_CODESIGN_DEV=\"${DESKFLOW_CODESIGN_ID:-$(security find-identity -v -p codesigning | awk '/Apple Development/{print $2; exit}')}\" -DSKIP_BUILD_TESTS=ON -DBUILD_TESTS=OFF",
      "windows": {
        "command": "$qtPath = $env:DESKFLOW_QT_PATH; if (-not $qtPath) { foreach ($c in @('C:\\Qt\\6.8.3\\msvc2022_64','C:\\Qt\\6.7.3\\msvc2022_64','C:\\Qt\\6.7.3\\msvc2019_64')) { if (Test-Path (Join-Path $c 'lib\\cmake\\Qt6\\Qt6Config.cmake')) { $qtPath = $c; break } }; if (-not $qtPath) { $found = Get-ChildItem 'C:\\Qt\\*\\msvc*_64\\lib\\cmake\\Qt6\\Qt6Config.cmake' -ErrorAction SilentlyContinue | Sort-Object FullName -Descending | Select-Object -First 1; if ($found) { $qtPath = (Resolve-Path (Join-Path $found.Directory.Parent.Parent.Parent.FullName)).Path } } }; if (-not $qtPath) { Write-Error 'Qt 6.7+ not found. Install via the Qt online installer or set DESKFLOW_QT_PATH.'; exit 1 }; Write-Host \"Using Qt at $qtPath\"; cmake -S . -B build -DCMAKE_BUILD_TYPE=Release -DSKIP_BUILD_TESTS=ON -DBUILD_TESTS=OFF \"-DCMAKE_PREFIX_PATH=$qtPath\""
      },
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Build + Sign",
      "type": "shell",
      "command": "cmake --build build -j$(sysctl -n hw.ncpu)",
      "windows": {
        "command": "cmake --build build --config Release -j $env:NUMBER_OF_PROCESSORS; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; $signtool = (Get-ChildItem 'C:\\Program Files*\\Windows Kits\\10\\bin\\*\\x64\\signtool.exe' -ErrorAction SilentlyContinue | Sort-Object FullName -Descending | Select-Object -First 1).FullName; $thumb = $env:DESKFLOW_SIGN_THUMBPRINT; if (-not $thumb) { $cert = Get-ChildItem Cert:\\CurrentUser\\My | Where-Object { $_.HasPrivateKey -and $_.Subject -match 'Mariner License Prep' } | Select-Object -First 1; if ($cert) { $thumb = $cert.Thumbprint } }; if ($thumb -and $signtool) { Get-ChildItem build\\bin\\*.exe, build\\bin\\Release\\*.exe -ErrorAction SilentlyContinue | ForEach-Object { & $signtool sign /fd SHA256 /tr http://timestamp.digicert.com /td SHA256 /sha1 $thumb $_.FullName; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE } }; Write-Host '== Signed with developer certificate ==' } else { Write-Host 'Built unsigned (no cert found; fine for local use).' }"
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Deskflow: Install locally",
      "type": "shell",
      "command": "bash scripts/install-macos.sh",
      "windows": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\install-windows.ps1\""
      },
      "detail": "Quit all Deskflow processes, reinstall to /Applications or Program Files, relaunch with --show",
      "problemMatcher": []
    },
    {
      "label": "Build, Sign & Install Deskflow",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Configure (signed)",
        "Deskflow: Build + Sign",
        "Deskflow: Install locally"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Configure (Debug)",
      "type": "shell",
      "command": "set -a; [ -f .env ] && . ./.env; set +a; cmake -S . -B build-debug -DCMAKE_BUILD_TYPE=Debug -DCMAKE_PREFIX_PATH=\"$(brew --prefix qt);$(brew --prefix openssl@3)\" -DAPPLE_CODESIGN_DEV=\"${DESKFLOW_CODESIGN_ID:-$(security find-identity -v -p codesigning | awk '/Apple Development/{print $2; exit}')}\" -DSKIP_BUILD_TESTS=ON -DBUILD_TESTS=OFF",
      "windows": {
        "command": "$qtPath = $env:DESKFLOW_QT_PATH; if (-not $qtPath) { foreach ($c in @('C:\\Qt\\6.8.3\\msvc2022_64','C:\\Qt\\6.7.3\\msvc2022_64','C:\\Qt\\6.7.3\\msvc2019_64')) { if (Test-Path (Join-Path $c 'lib\\cmake\\Qt6\\Qt6Config.cmake')) { $qtPath = $c; break } }; if (-not $qtPath) { $found = Get-ChildItem 'C:\\Qt\\*\\msvc*_64\\lib\\cmake\\Qt6\\Qt6Config.cmake' -ErrorAction SilentlyContinue | Sort-Object FullName -Descending | Select-Object -First 1; if ($found) { $qtPath = (Resolve-Path (Join-Path $found.Directory.Parent.Parent.Parent.FullName)).Path } } }; if (-not $qtPath) { Write-Error 'Qt 6.7+ not found. Install via the Qt online installer or set DESKFLOW_QT_PATH.'; exit 1 }; Write-Host \"Using Qt at $qtPath\"; cmake -S . -B build-debug -DCMAKE_BUILD_TYPE=Debug -DSKIP_BUILD_TESTS=ON -DBUILD_TESTS=OFF \"-DCMAKE_PREFIX_PATH=$qtPath\""
      },
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Build (Debug)",
      "type": "shell",
      "command": "cmake --build build-debug -j$(sysctl -n hw.ncpu)",
      "windows": {
        "command": "cmake --build build-debug --config Debug -j $env:NUMBER_OF_PROCESSORS"
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Deskflow: Configure (Debug) + Build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Configure (Debug)",
        "Deskflow: Build (Debug)"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Sync production settings (macOS)",
      "type": "shell",
      "command": "bash scripts/sync-debug-settings-macos.sh",
      "detail": "Ensure coordination/peers and other connection settings match the installed app (~/Library/Deskflow)",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Sync production settings (Windows)",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\sync-debug-settings-windows.ps1\"",
      "detail": "Ensure coordination/peers match the installed app (%APPDATA%\\Deskflow); sharing keys stay in Deskflow.conf",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Prepare Debug Session (macOS)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (macOS)",
        "Deskflow: Sync production settings (macOS)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Prepare Debug Session (Windows)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (Windows)",
        "Deskflow: Sync production settings (Windows)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Quit all (macOS)",
      "type": "shell",
      "command": "osascript -e 'tell application \"Deskflow\" to quit' 2>/dev/null || true; for pat in deskflow-core Deskflow.app/Contents/MacOS/Deskflow deskflow-vhid-bridge; do pkill -f \"$pat\" 2>/dev/null || true; done; sleep 0.5; for pat in deskflow-core Deskflow.app/Contents/MacOS/Deskflow deskflow-vhid-bridge; do pkill -9 -f \"$pat\" 2>/dev/null || true; done; echo 'Deskflow processes stopped.'",
      "detail": "Stop GUI, deskflow-core, and vhid-bridge before debugging (avoids single-instance conflicts)",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Quit all (Windows)",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\quit-all-windows.ps1\"",
      "detail": "Stop service, GUI, deskflow-core, daemon, and vhid-bridge before debugging",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run GUI (Debug, local)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (macOS)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "open \"${workspaceFolder}/build-debug/bin/Deskflow.app\" --args --show",
      "detail": "Build debug bundle and launch Deskflow locally (no /Applications install)",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run Core (Debug, client)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (macOS)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "\"${workspaceFolder}/build-debug/bin/Deskflow.app/Contents/MacOS/deskflow-core\" client --settings \"${env:HOME}/Library/Deskflow/Deskflow.conf\"",
      "detail": "Run deskflow-core in client mode from the debug bundle",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run Core (Debug, server)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (macOS)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "\"${workspaceFolder}/build-debug/bin/Deskflow.app/Contents/MacOS/deskflow-core\" server --settings \"${env:HOME}/Library/Deskflow/Deskflow.conf\"",
      "detail": "Run deskflow-core in server mode from the debug bundle",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run Core (Debug, auto)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (macOS)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "\"${workspaceFolder}/build-debug/bin/Deskflow.app/Contents/MacOS/deskflow-core\" auto --settings \"${env:HOME}/Library/Deskflow/Deskflow.conf\"",
      "detail": "Run deskflow-core in auto mode from the debug bundle",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run GUI (Debug, local, Windows)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (Windows)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "powershell -NoProfile -Command \"Start-Process -FilePath '${workspaceFolder}/build-debug/bin/Debug/deskflow.exe' -ArgumentList '--show' -WorkingDirectory '${workspaceFolder}'\"",
      "windows": {
        "command": "powershell -NoProfile -Command \"Start-Process -FilePath '${workspaceFolder}\\build-debug\\bin\\Debug\\deskflow.exe' -ArgumentList '--show' -WorkingDirectory '${workspaceFolder}'\""
      },
      "detail": "Build debug binaries and launch deskflow.exe locally (no Program Files install)",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run Core (Debug, client, Windows)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (Windows)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "powershell -NoProfile -Command \"& '${workspaceFolder}/build-debug/bin/Debug/deskflow-core.exe' client --settings $env:APPDATA\\Deskflow\\Deskflow.conf\"",
      "windows": {
        "command": "& \"${workspaceFolder}\\build-debug\\bin\\Debug\\deskflow-core.exe\" client --settings \"$env:APPDATA\\Deskflow\\Deskflow.conf\""
      },
      "detail": "Run deskflow-core in client mode from the debug build",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run Core (Debug, server, Windows)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (Windows)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "powershell -NoProfile -Command \"& '${workspaceFolder}/build-debug/bin/Debug/deskflow-core.exe' server --settings $env:APPDATA\\Deskflow\\Deskflow.conf\"",
      "windows": {
        "command": "& \"${workspaceFolder}\\build-debug\\bin\\Debug\\deskflow-core.exe\" server --settings \"$env:APPDATA\\Deskflow\\Deskflow.conf\""
      },
      "detail": "Run deskflow-core in server mode from the debug build",
      "problemMatcher": []
    },
    {
      "label": "Deskflow: Run Core (Debug, auto, Windows)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Deskflow: Quit all (Windows)",
        "Deskflow: Configure (Debug) + Build"
      ],
      "type": "shell",
      "command": "powershell -NoProfile -Command \"& '${workspaceFolder}/build-debug/bin/Debug/deskflow-core.exe' auto --settings $env:APPDATA\\Deskflow\\Deskflow.conf\"",
      "windows": {
        "command": "& \"${workspaceFolder}\\build-debug\\bin\\Debug\\deskflow-core.exe\" auto --settings \"$env:APPDATA\\Deskflow\\Deskflow.conf\""
      },
      "detail": "Run deskflow-core in auto mode from the debug build",
      "problemMatcher": []
    }
  ]
}
