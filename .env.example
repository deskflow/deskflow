# Per-machine build/signing config for Deskflow.
# Copy to `.env` (gitignored) on each machine and fill in the values for THAT box.
# The macOS VSCode build task and scripts/build-windows.ps1 both read `.env`.

# ===== macOS (code signing) =====
# Your Apple Development cert's SHA-1 HASH (use the hash, not the name -- the
# hash is unambiguous even if you have two same-named certs in the keychain).
# Find it with:  security find-identity -v -p codesigning
DESKFLOW_CODESIGN_ID=

# Optional: override settings directory for sync-debug-settings-macos.sh (default ~/Library/Deskflow)
# DESKFLOW_SETTINGS_DIR=

# ===== Windows (build dependencies) =====
# Qt msvc kit prefix and OpenSSL root, passed to CMake by scripts/build-windows.ps1.
QT_PREFIX=C:/Qt/6.8.3/msvc2022_64
OPENSSL_ROOT_DIR=C:/Users/you/scoop/apps/openssl/current
