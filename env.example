# Copy to .env and adjust for your machine.
# Deskflow build/install settings (loaded by .vscode/tasks.json and scripts/*.ps1 / install-macos.sh)

# macOS: Apple Development codesign identity
DESKFLOW_CODESIGN_ID=

# macOS: install destination (.app bundle path)
DESKFLOW_INSTALL_APP=/Applications/Deskflow.app

# Windows: Qt install prefix (leave empty to auto-detect under C:\Qt)
DESKFLOW_QT_PATH=

# Windows: OpenSSL install root (e.g. C:\Program Files\OpenSSL-Win64)
OPENSSL_ROOT_DIR=

# Windows: Authenticode cert thumbprint (leave empty to auto-detect)
DESKFLOW_SIGN_THUMBPRINT=

# Windows: install location (must be a full path, e.g. C:\Program Files\Deskflow — not C:\Program)
DESKFLOW_INSTALL_DIR=

# Build output directory (relative to repo root)
DESKFLOW_BUILD_DIR=build

# Login screen / UAC: configured in Deskflow GUI (Settings -> Advanced), not here.
# Requires the installed (Program Files) build + Deskflow Windows service + Start once while logged in.
